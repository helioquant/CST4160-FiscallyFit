# FiscallyFit Environment Variables
# Copy this file to .env and fill in your API keys

# Finnhub API key (free at https://finnhub.io)
FINNHUB_API_KEY=

# Exchange Rate API key (free at https://exchangeratesapi.io or https://frankfurter.app is used as fallback)
FX_API_KEY=''

# SQLite database path (default: fiscallyfit.db in project root)
DB_PATH=

# Secret key for hashing (change this in production!)
SECRET_KEY=
